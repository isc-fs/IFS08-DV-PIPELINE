#!/usr/bin/env bash
# dv — DVPC racing-operation control + status
# Usage: dv {race|manual [stop]|replay <bag> [mission]|stop|restart|update|mode [race|umbilical|auto]|status}
#
# Versioned in IFS08-DV-PIPELINE/deploy/ (installed to /usr/local/bin by
# install_dv_pipeline_service.sh). Racing operation = dv-pipeline.service
# (the real pipeline from dv_ws); the old isc-startup stub stack is legacy.
# `dv manual` = dv-manual.service: record a manual-driving bag (sensors only,
# no autonomy). `dv stop` stops BOTH units. `dv replay` = off-line bench tool
# (tools/record_pipeline_replay.sh): replays a bag through the pipeline in
# sim-time with a simulated uDV mission and records inputs+outputs; not a
# systemd unit, runs in the foreground from the workspace checkout.
set -uo pipefail
_mark(){ cat /proc/sys/kernel/random/boot_id > "$HOME/.dv_decision" 2>/dev/null || true; }

case "${1:-status}" in
  # Stop the manual recorder FIRST (it and the pipeline both launch the Hesai
  # driver — running both fights over the lidar), then start the pipeline. With
  # mission-gating the manual recorder is usually already stopped by the time a
  # real mission is confirmed, but this closes the confirm→`dv race` window.
  race)    sudo -n systemctl stop dv-manual.service 2>/dev/null; \
           sudo -n systemctl start dv-pipeline.service && echo "[dv] racing operation started"   ; _mark ;;
  # Manual-driving recorder: sensors + bag, no pipeline. `dv manual` starts,
  # `dv manual stop` stops just this unit. Refuses to start while the pipeline
  # is up (both launch the Hesai driver — running both fights over it).
  manual)
    if [ "${2:-}" = "stop" ]; then
      sudo -n systemctl stop dv-manual.service && echo "[dv] manual recording stopped"
    elif systemctl is-active --quiet dv-pipeline.service; then
      echo "[dv] pipeline is running — 'dv stop' it first (both use the Hesai driver)"; exit 1
    else
      sudo -n systemctl start dv-manual.service && echo "[dv] manual recording started (sensors only, bag: manual_*)"
    fi ;;
  # Off-line bench replay: feed a recorded bag back through the pipeline in
  # sim-time with a simulated uDV mission, recording inputs+outputs to a new
  # ~/bags/bench_* bag for perf/offline analysis. Not a systemd unit — it runs
  # the workspace tool in the foreground and passes args straight through
  # (dv replay <source_bag> [mission] [output_name]). Refused while the pipeline
  # or manual recorder is up: replay spins its own sim pipeline on the ROS graph
  # and would collide with a live one.
  replay)
    shift
    tool="$HOME/dv_ws/src/IFS08-DV-PIPELINE/tools/record_pipeline_replay.sh"
    if systemctl is-active --quiet dv-pipeline.service || systemctl is-active --quiet dv-manual.service; then
      echo "[dv] pipeline/manual is running — 'dv stop' first (replay drives its own sim pipeline)"; exit 1
    fi
    [ -x "$tool" ] || { echo "[dv] replay tool missing: $tool (update the workspace)"; exit 1; }
    if [ -z "${1:-}" ]; then
      echo "usage: dv replay <source_bag> [mission] [output_name]"
      echo "  e.g. dv replay ~/bags/manual_20260720_2130 trackdrive"; exit 1
    fi
    "$tool" "$@" ;;
  # Stop BOTH the racing pipeline and the manual recorder, whichever is up.
  stop)    sudo -n systemctl stop dv-pipeline.service dv-manual.service && echo "[dv] stopped (pipeline + manual)" ; _mark ;;
  restart) sudo -n systemctl stop dv-manual.service 2>/dev/null; \
           sudo -n systemctl restart dv-pipeline.service && echo "[dv] racing operation restarted" ;;
  # After a successful update, re-bake the Numba JIT cache: the update
  # rewrites sources, which is exactly what invalidates it. Baking now (on
  # the bench) keeps race-mode bring-up on the warm path (~1 s/node) instead
  # of a ~1-2 min cold JIT. Best-effort — the warm script always exits 0.
  update)  /home/isc/dv_pipeline_update.sh && /usr/local/bin/dv_warm_numba.sh ;;
  mode)
    # No arg: report the mode picked at boot. Arg: set/clear the boot-mode
    # override read by dv_detect_mode.sh (effective next boot; /etc/dv is
    # isc-owned by the installer so no sudo is needed here).
    case "${2:-}" in
      "")             cat /run/dv_mode 2>/dev/null || echo unknown ;;
      race|umbilical)
        if ( printf '%s\n' "$2" > /etc/dv/mode ) 2>/dev/null; then
          echo "[dv] boot-mode override set to '$2' (effective next boot; use 'dv race' to act now)"
        else
          echo "[dv] cannot write /etc/dv/mode — run the installer, or: sudo install -d -o isc /etc/dv"; exit 1
        fi ;;
      auto|clear)
        rm -f /etc/dv/mode 2>/dev/null || true
        echo "[dv] boot-mode override cleared (autodetect from enp2s0 carrier)" ;;
      *) echo "usage: dv mode [race|umbilical|auto]"; exit 1 ;;
    esac ;;
  status)
    echo "mode:         $(cat /run/dv_mode 2>/dev/null || echo unknown)  (enp2s0 carrier=$(cat /sys/class/net/enp2s0/carrier 2>/dev/null || echo ?), override=$(cat /etc/dv/mode 2>/dev/null || echo auto))"
    echo "pipeline:     health=$(cat /run/dv_pipeline_health 2>/dev/null || echo unknown)"
    for s in dv-pipeline dv-manual dv-automission dv-record microros-agent ptp4l dv-mode isc-startup; do
      printf "%-16s %s\n" "$s:" "$(systemctl is-active "$s" 2>/dev/null)"
    done
    echo "last bag:     $(ls -1dt /home/isc/bags/*/ 2>/dev/null | head -1 || echo none)"
    echo "last update:  $(tail -1 /home/isc/dv_ws/update_status.txt 2>/dev/null || echo none)"
    ;;
  *) echo "usage: dv {race|manual [stop]|replay <bag> [mission]|stop|restart|update|mode [race|umbilical|auto]|status}"; exit 1 ;;
esac
